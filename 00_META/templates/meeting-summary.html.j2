<!DOCTYPE html>
<html lang="$if(lang)$$lang$$else$es$endif$">
<head>
  <meta charset="utf-8">
  <meta name="generator" content="pandoc + weasyprint">
  <title>$if(pagetitle)$$pagetitle$$else$$title$$endif$</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet">
$for(css)$
  <link rel="stylesheet" href="$css$">
$endfor$
</head>
<body>

  <!-- Per-page running header (rendered via position:running in CSS) -->
  <div class="page-header" role="banner">
    <span class="brand-mark">NEXOSTRAT</span>
  </div>

  <main class="document">

$if(title)$
    <header class="doc-cover">
      <img class="cover-logo" src="/srv/Nexostrat/00_META/templates/assets/logo.png" alt="Nexostrat">
      <h1 class="doc-title">$title$</h1>
$if(subtitle)$      <p class="doc-subtitle">$subtitle$</p>
$endif$$if(date)$      <p class="doc-date">$date$</p>
$endif$    </header>
$endif$

$body$

  </main>
</body>
</html>
