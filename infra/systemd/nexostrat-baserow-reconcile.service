[Unit]
Description=Nexostrat — nightly Baserow deliverables reconcile
After=nexostrat-foss-stack.service

[Service]
Type=oneshot
User=ricardo
WorkingDirectory=/srv/Nexostrat
ExecStart=/srv/Nexostrat/infra/scripts/run-with-secrets.sh /srv/Nexostrat/infra/scripts/baserow-reconcile.sh
StandardOutput=journal
StandardError=journal
